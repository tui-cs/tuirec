{
  "name": "tuicast",
  "version": "0.1.0",
  "description": "AI-Powered Terminal GIF Generation for Terminal.Gui Developers",
  "main": "dist/api/server.js",
  "scripts": {
    "build": "tsc",
    "start:api": "node dist/api/server.js",
    "start:worker": "node dist/worker/worker.js",
    "record": "ts-node src/cli/record.ts",
    "dev:api": "ts-node-dev --respawn src/api/server.ts",
    "dev:worker": "ts-node-dev --respawn src/worker/worker.ts",
    "lint": "eslint src --ext .ts",
    "test": "jest --passWithNoTests"
  },
  "keywords": [
    "terminal",
    "gif",
    "tui",
    "terminal-gui",
    "asciinema",
    "claude",
    "ai"
  ],
  "author": "gui-cs",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@azure/service-bus": "^7.9.5",
    "@azure/storage-blob": "^12.26.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "multer": "^2.1.1",
    "node-pty": "^1.0.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.10",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "eslint": "^9.22.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ]
  }
}
