# =============================================================================
# TUIcast – Environment Variables
# Copy this file to .env and fill in the values.
# =============================================================================

# ─── API ─────────────────────────────────────────────────────────────────────
PORT=3000

# ─── Anthropic ───────────────────────────────────────────────────────────────
# Your Anthropic API key (https://console.anthropic.com).
ANTHROPIC_API_KEY=

# Claude model to use for the AI navigation loop.
# Default: claude-opus-4-5
CLAUDE_MODEL=claude-opus-4-5

# Maximum number of turns the AI loop will take per job.
# Default: 30
CLAUDE_MAX_TURNS=30

# ─── Azure Service Bus ───────────────────────────────────────────────────────
# Connection string for the Azure Service Bus namespace.
# Leave empty to run without a queue (jobs are processed inline by the API).
SERVICE_BUS_CONNECTION_STRING=

# Name of the queue to use.
SERVICE_BUS_QUEUE_NAME=tuicast-jobs

# Set to "false" to skip enqueueing and process jobs inline (development mode).
USE_QUEUE=false

# ─── Azure Blob Storage ──────────────────────────────────────────────────────
# Connection string for the Azure Storage account.
# Use "UseDevelopmentStorage=true" to connect to a local Azurite emulator.
STORAGE_CONNECTION_STRING=UseDevelopmentStorage=true

# Container names (created automatically if they don't exist).
STORAGE_CONTAINER_GIFS=gifs
STORAGE_CONTAINER_CASTS=casts
STORAGE_CONTAINER_BINARIES=binaries

# Presigned URL TTL in seconds (default: 3600 = 1 hour).
STORAGE_SAS_TTL_SECONDS=3600

# ─── GIF Renderer (agg) ──────────────────────────────────────────────────────
# Path to the agg binary. Defaults to "agg" (assumes it is on PATH).
AGG_PATH=agg
